# LLM Provider Configuration
# Set the provider you want to use: openai, claude, gemini, deepseek, local
# Default: openai
LLM_PROVIDER=openai

# Optional: Override the default model for your provider
# Examples:
#   LLM_MODEL=gpt-4o (for OpenAI)
#   LLM_MODEL=claude-3-5-sonnet-20241022 (for Claude)
#   LLM_MODEL=gemini-2.0-flash-exp (for Gemini)
#   LLM_MODEL=deepseek-chat (for DeepSeek)
#   LLM_MODEL=llama3.2 (for Ollama)
# LLM_MODEL=

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude Configuration
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini Configuration
# GOOGLE_API_KEY=your-google-api-key-here

# DeepSeek Configuration
# DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Local Model Configuration (Ollama)
# Set this if your Ollama server is running on a different port
# OLLAMA_BASE_URL=http://localhost:11434
